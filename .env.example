# ReverseClaw Environment Variables
# This example was placed here because your incompetence is expected. You basically use your computer like a paint by numbers system anyways.
# The API Key for your LLM provider.
OPENAI_API_KEY="your-api-key-here"

# Leave blank for default OpenAI, or set for vLLM, Groq, Ollama, your mom, Gemini, Claude etc.
# Examples:
# vLLM: http://localhost:8000/v1
# Groq: https://api.groq.com/openai/v1
# Ollama: http://localhost:11434/v1
OPENAI_BASE_URL=""

# The model to use. 
# Defaults to "gpt-4o" but change to your locally running vLLM model or Groq model.
# e.g., "llama3-70b-8192" or "mistral-8x7b-32768"
MODEL_NAME="gpt-4o"
