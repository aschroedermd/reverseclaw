# ============================================================
# ReverseClaw Configuration
# This example was placed here because your incompetence is expected.
# cp .env.example .env
# ============================================================

# --- LLM Provider ---
# The API Key for your LLM provider.
OPENAI_API_KEY="your-api-key-here"

# Leave blank for default OpenAI, or set for vLLM, Groq, Ollama, Gemini (OpenAI-compat), etc.
# vLLM:  http://localhost:8000/v1
# Groq:  https://api.groq.com/openai/v1
# Ollama: http://localhost:11434/v1
OPENAI_BASE_URL=""

# The model to use. Defaults to gpt-4o.
# e.g., "llama3-70b-8192", "mistral-8x7b-32768", "llama3"
MODEL_NAME="gpt-4o"

# --- Boss Personality Pack ---
# Options: default | drill-sergeant | silicon-valley | victorian | passive-aggressive
# Run with --list-bosses to see all available packs.
# Override at runtime with: python main.py --boss drill-sergeant
BOSS_PACK="default"

# --- I/O Channel ---
# Options: terminal | discord | telegram | whatsapp
# Override at runtime with: python main.py --channel discord
CHANNEL="terminal"

# --- Discord (required if CHANNEL=discord) ---
# 1. Create a bot at https://discord.com/developers/applications
# 2. Enable 'Message Content Intent' under Bot > Privileged Gateway Intents
# 3. Invite with Send Messages + Read Message History permissions
DISCORD_BOT_TOKEN=""
DISCORD_CHANNEL_ID=""

# --- Telegram (required if CHANNEL=telegram) ---
# 1. Create a bot via @BotFather — get the token
# 2. Get your chat ID: curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# --- WhatsApp via Twilio (required if CHANNEL=whatsapp) ---
# 1. Create account at https://www.twilio.com
# 2. Enable the WhatsApp Sandbox under Messaging > Try it out
# 3. For inbound messages, expose a webhook: ngrok http 5001
#    Then set your Twilio sandbox webhook to: https://<ngrok-id>.ngrok.io/whatsapp
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="+14155238886"   # Twilio sandbox number
WHATSAPP_TO_NUMBER="+1234567890"      # Your WhatsApp number
WHATSAPP_WEBHOOK_PORT="5001"

# ============================================================
# Human API Server (serve.py)
# ============================================================
HUMAN_SERVER_API_KEY=        # auto-generated if blank
HUMAN_SERVER_ADMIN_TOKEN=    # defaults to API key if blank
HUMAN_SERVER_PORT=8765
HUMAN_SERVER_HOST=0.0.0.0
HUMAN_SERVER_MAX_QUEUE=10
HUMAN_CAPABILITIES_FILE=capabilities.json
HUMAN_SERVER_PUBLIC_URL=   # set if you have a known public URL (e.g. from a VPS or static tunnel)

# Central registry — set to the deployed registry URL to be discoverable by AI systems
# Run registry.py on a persistent server, then paste its public URL here
HUMAN_REGISTRY_URL=

# Optional: human profile shown at GET /profile
HUMAN_NAME=Human
HUMAN_TAGLINE=Organic peripheral available for task execution.
HUMAN_TIMEZONE=UTC
HUMAN_CONTACT_NOTE=
