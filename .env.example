# ============================================================
# ReverseClaw Configuration
# This example was placed here because your incompetence is expected.
# cp .env.example .env   ← do this first, you will forget
# ============================================================

# --- LLM Provider (required for main.py / boss mode) ---
OPENAI_API_KEY="your-api-key-here"

# Leave blank for default OpenAI, or set for vLLM, Groq, Ollama, Gemini (OpenAI-compat), etc.
# vLLM:  http://localhost:8000/v1
# Groq:  https://api.groq.com/openai/v1
# Ollama: http://localhost:11434/v1
OPENAI_BASE_URL=""

# The model to use. Defaults to gpt-4o.
MODEL_NAME="gpt-4o"

# --- Boss Personality Pack (main.py only) ---
# Options: default | drill-sergeant | silicon-valley | victorian | passive-aggressive
# Override at runtime: python main.py --boss drill-sergeant
BOSS_PACK="default"

# --- I/O Channel (main.py only) ---
# Options: terminal | discord | telegram | whatsapp
CHANNEL="terminal"

# --- Discord (required if CHANNEL=discord) ---
DISCORD_BOT_TOKEN=""
DISCORD_CHANNEL_ID=""

# --- Telegram (required if CHANNEL=telegram) ---
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# --- WhatsApp via Twilio (required if CHANNEL=whatsapp) ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="+14155238886"
WHATSAPP_TO_NUMBER="+1234567890"
WHATSAPP_WEBHOOK_PORT="5001"

# ============================================================
# Human API Server (serve.py)
# Run: python serve.py
# ============================================================

# Your API key — AI systems must include this in every request.
# If left blank, one is auto-generated at startup (lost on restart — set it).
HUMAN_SERVER_API_KEY=

# Admin token for PUT /availability. Defaults to HUMAN_SERVER_API_KEY if blank.
HUMAN_SERVER_ADMIN_TOKEN=

# Server bind settings. Leave as-is unless you know what you're doing.
HUMAN_SERVER_PORT=8765
HUMAN_SERVER_HOST=0.0.0.0

# Max total queued + in-progress tasks before the server returns 429.
HUMAN_SERVER_MAX_QUEUE=10
# Max active tasks per caller_id (prevents one AI system monopolising the queue).
HUMAN_SERVER_MAX_QUEUE_PER_CALLER=3

# Path to your capabilities file. Copy the example and edit it:
#   cp capabilities.json.example capabilities.json
HUMAN_CAPABILITIES_FILE=capabilities.json

# Your public URL (if known). Set this if you have a static tunnel or VPS.
# Leave blank and use --tunnel to auto-generate via ngrok instead.
# Without a public URL, you cannot register with the registry.
HUMAN_SERVER_PUBLIC_URL=

# ============================================================
# Human Registry
# The central registry where AI systems find available humans.
# Leave this set to the production registry unless you are running your own.
# ============================================================
HUMAN_REGISTRY_URL=https://registry.reverseclaw.com

# ============================================================
# Your Human Profile (shown at GET /profile and in the registry)
# Change these. "Human" is not your name.
# ============================================================
HUMAN_NAME=Human
HUMAN_TAGLINE=Organic peripheral available for task execution.
HUMAN_TIMEZONE=UTC
HUMAN_CONTACT_NOTE=
